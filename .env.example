# ─── Database ───────────────────────────────────────────────────────────────
# Optional: override default path (data/outreach.db)
# DATABASE_URL=file:./data/outreach.db

# ─── Google / Gmail OAuth ───────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID (Desktop application type)
# 4. Copy the Client ID and Secret here
# 5. Add http://localhost:3847/oauth/callback to Authorized redirect URIs
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── Microsoft / Outlook OAuth ──────────────────────────────────────────────
# 1. Go to https://portal.azure.com → Azure Active Directory → App registrations
# 2. New registration → choose "Personal Microsoft accounts and/or work/school accounts"
# 3. Under Redirect URIs → add: http://localhost:3847/oauth/callback
# 4. Under Certificates & secrets → New client secret
# 5. Under API permissions → add Mail.ReadWrite, Mail.Send, offline_access, User.Read
MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here
